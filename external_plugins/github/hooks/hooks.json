{
  "description": "Auto-allow gh CLI and bundled Python helper commands so the GitHub plugin works in sandbox mode without manual approval.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/allow-gh.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-gh-auth.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
